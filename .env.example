# Azure AI Services endpoint (multi-service account)
AZURE_AI_SERVICES_ENDPOINT=https://<your-ai-services>.services.ai.azure.com

# Azure AI Foundry project (optional, for project-scoped access)
AZURE_AI_PROJECT_NAME=proj-default
AZURE_AI_PROJECT_URL=https://<your-ai-services>.services.ai.azure.com/api/projects/proj-default

# Azure subscription and resource group
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# Azure AI Services account details
AZURE_AI_SERVICES_ACCOUNT=
AZURE_AI_SERVICES_RESOURCE_ID=

# Azure OpenAI model deployment name
AZURE_OPENAI_DEPLOYMENT=gpt-5.4

# Azure Blob Storage account URL (for captured image archival)
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage>.blob.core.windows.net

# Enable verbose timing logs (set to false in production)
DEBUG=true
