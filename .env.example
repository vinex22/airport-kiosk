# Azure AI Services endpoint (multi-service account)
AZURE_AI_SERVICES_ENDPOINT=https://<your-ai-services>.services.ai.azure.com

# Azure subscription and resource group
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# Azure OpenAI model deployment name
AZURE_OPENAI_DEPLOYMENT=gpt-5.4

# Azure Blob Storage account URL (for scanned image archival)
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage>.blob.core.windows.net

# Enable verbose timing logs (set to false in production)
DEBUG=true
