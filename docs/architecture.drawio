          <mxGeometry x="805" y="115" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- Blob Storage box -->
        <mxCell id="blob" value="&lt;b&gt;Blob Storage&lt;/b&gt;&lt;br&gt;Image archival" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=12;verticalAlign=bottom;" parent="1" vertex="1">
          <mxGeometry x="730" y="340" width="200" height="100" as="geometry"/>
