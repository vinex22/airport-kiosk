          <mxGeometry x="475" y="405" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- ========== NUMBERED ARROWS ========== -->

        <!-- 1: Device → App Service -->
        <mxCell id="e1" value="&lt;b&gt;1&lt;/b&gt;  POST /check (photo)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#0078D4;fontColor=#0078D4;fontSize=11;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.35;entryDx=0;entryDy=0;" parent="1" source="device" target="appservice" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 2: App Service → Azure OpenAI -->
        <mxCell id="e2" value="&lt;b&gt;2&lt;/b&gt;  chat.completions (stream)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;fontColor=#82b366;fontSize=11;" parent="1" source="appservice" target="openai" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 3: App Service → Blob Storage -->
        <mxCell id="e3" value="&lt;b&gt;3&lt;/b&gt;  upload_blob()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#d6b656;fontColor=#d6b656;fontSize=11;dashed=1;" parent="1" source="appservice" target="blob" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 4: App Service → Device (SSE response) -->
        <mxCell id="e4" value="&lt;b&gt;4&lt;/b&gt;  SSE verdict (Allowed / Prohibited)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#c62828;fontColor=#c62828;fontSize=11;dashed=1;exitX=0;exitY=0.75;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;" parent="1" source="appservice" target="device" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Auth: Managed Identity → App Service -->
        <mxCell id="e-auth" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1;strokeColor=#999999;dashed=1;fontSize=10;fontColor=#999999;" parent="1" source="mi" target="appservice" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========== LEGEND ========== -->
        <mxCell id="legend" value="&lt;b&gt;Flow&lt;/b&gt;&lt;br&gt;1. Passenger scans item via phone or kiosk camera&lt;br&gt;2. Image sent to GPT-5.4 for ICAO rule check (streaming)&lt;br&gt;3. Image archived to Blob Storage&lt;br&gt;4. Streaming verdict returned to browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9cc;strokeColor=#d6b656;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;verticalAlign=middle;fontColor=#333333;" parent="1" vertex="1">
